# Calendar source — set EXACTLY ONE of the two below. If HOSTEX_ACCESS_TOKEN
# is set it takes precedence and the dashboard shows the Hostex availability
# calendar; otherwise ICAL_URL drives the event-list view.

# Option A — Google Calendar private ICS URL (treat as a secret).
ICAL_URL=

# Option B — Hostex OpenAPI access token (treat as a secret). Shows a
# reservation timeline for every home the token covers.
HOSTEX_ACCESS_TOKEN=

# Optional. Server listen port.
PORT=5174

# Optional. Max events to display in the ICS view (baked into the client at
# build time; ignored by the Hostex calendar).
NEXT_N=12

# Optional. Page reload interval in ms (baked into the client at build time).
REFRESH_MS=300000

# Optional. Enable Plow-posted messages (morning affirmations etc.).
# Both must be set or the /api/message route is not registered.
MESSAGE_API_URL=
DASHBOARD_TOKEN=
