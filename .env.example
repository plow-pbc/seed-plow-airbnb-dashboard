# Calendar sources — set ICAL_URL, HOSTEX_ACCESS_TOKEN, and/or a Guesty
# credential pair. Each source configured becomes its own dashboard panel;
# set multiple to show them side-by-side. At least one is required.

# Google Calendar private ICS URL (treat as a secret) — an upcoming-events panel.
ICAL_URL=

# Hostex OpenAPI access token (treat as a secret) — a reservation-timeline
# panel covering every home the token sees.
HOSTEX_ACCESS_TOKEN=

# Guesty Open API credentials (treat as secrets) — adds a Guesty reservation-
# timeline panel. Both must be set for the panel to appear. The cached bearer
# is persisted to .guesty-token.json (gitignored) and reused across restarts,
# because Guesty enforces a hard cap of 5 token issuances per client_id /
# 24h.
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Optional. Override the Guesty Open API base URL. Defaults to
# https://open-api.guesty.com. Point at http://localhost:8787 (or wherever
# you've started guesty-dtu — see guesty-dtu/README.md) for local dev and CI
# so you don't burn real OAuth tokens.
GUESTY_API_BASE=

# Optional. Server listen port.
PORT=5174

# Optional. Max events to display in the ICS view (baked into the client at
# build time; ignored by the Hostex calendar).
NEXT_N=12

# Optional. Page reload interval in ms (baked into the client at build time).
REFRESH_MS=300000

# Optional. Enable Plow-posted messages (morning affirmations etc.).
# Both must be set or the /api/message route is not registered.
MESSAGE_API_URL=
DASHBOARD_TOKEN=
