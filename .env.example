# Calendar sources — set ICAL_URL and/or HOSTEX_ACCESS_TOKEN. Each one set
# becomes its own dashboard panel; set both to show both. At least one is
# required.

# Google Calendar private ICS URL (treat as a secret) — an upcoming-events panel.
ICAL_URL=

# Hostex OpenAPI access token (treat as a secret) — a reservation-timeline
# panel covering every home the token sees.
HOSTEX_ACCESS_TOKEN=

# Optional. Server listen port.
PORT=5174

# Optional. Max events to display in the ICS view (baked into the client at
# build time; ignored by the Hostex calendar).
NEXT_N=12

# Optional. Page reload interval in ms (baked into the client at build time).
REFRESH_MS=300000

# Optional. Enable Plow-posted messages (morning affirmations etc.).
# Both must be set or the /api/message route is not registered.
MESSAGE_API_URL=
DASHBOARD_TOKEN=
