# Required: full Google Calendar private ICS URL (treat as a secret)
ICAL_URL=

# Optional. Server listen port.
PORT=5174

# Optional. Max events to display (baked into the client at build time).
NEXT_N=12

# Optional. Page reload interval in ms (baked into the client at build time).
REFRESH_MS=300000

# Optional. Enable Plow-posted messages (morning affirmations etc.).
# Both must be set or the /api/message route is not registered.
MESSAGE_API_URL=
DASHBOARD_TOKEN=
