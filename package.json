{
  "name": "plow-airbnb-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "dev:client": "vite",
    "dev:server": "node --watch --env-file=.env server.js",
    "dev": "concurrently -k -n vite,server -c blue,green 'npm:dev:client' 'npm:dev:server'",
    "build": "tsc -b && vite build",
    "start": "node --env-file=.env server.js",
    "test": "TZ=America/Los_Angeles vitest run",
    "test:watch": "TZ=America/Los_Angeles vitest",
    "lint": "tsc --noEmit && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "ical.js": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
